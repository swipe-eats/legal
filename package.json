{
  "name": "@swipe-eats/legal",
  "version": "0.1.0",
  "description": "Shared legal documents for Swipe Eats.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/generate-documents.mjs && tsc -p tsconfig.json",
    "check": "node scripts/generate-documents.mjs --check && tsc -p tsconfig.json --noEmit",
    "generate": "node scripts/generate-documents.mjs"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
